{
  "name": "leedswire",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:ads": "NEXT_PUBLIC_LEEDSWIRE_TEST_ADS=true NEXT_PUBLIC_LEEDSWIRE_TEST_POPUP=true NEXT_PUBLIC_LEEDSWIRE_TEST_POPUP_FORCE_VIEW=true next dev",
    "prebuild": "node scripts/validate-ad-assets.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "tsc -p tsconfig.test.json && node .test-build/tests/news-filter.test.js && node .test-build/tests/article-url.test.js && node .test-build/tests/ad-fallback.test.js && node .test-build/tests/freshness.test.js && node .test-build/tests/text.test.js",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
